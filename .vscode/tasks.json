{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "command": "npm",
      "args": [
        "run",
        "watch"
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": "$tsc-watch",
      "runOptions": {
        "runOn": "folderOpen"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "compile",
      "command": "npm",
      "args": [
        "run",
        "compile"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": "$tsc",
      "group": {
        "kind": "build"
      }
    }
  ]
}
