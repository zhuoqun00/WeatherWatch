{
  "name": "weatherwatch",
  "displayName": "WeatherWatch",
  "description": "在VS Code状态栏实时显示天气信息，支持自动位置检测和多种天气参数 | Real-time weather display in VS Code status bar with auto location detection",
  "version": "1.0.4",
  "publisher": "ZhuoqunLi",
  "icon": "media/icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "weather",
    "天气",
    "status bar",
    "location",
    "meteo",
    "climate",
    "forecast"
  ],
  "homepage": "https://github.com/zhuoqun00/WeatherWatch",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhuoqun00/WeatherWatch.git"
  },
  "bugs": {
    "url": "https://github.com/zhuoqun00/WeatherWatch/issues"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy-i18n",
    "compile": "tsc -p ./",
    "copy-i18n": "mkdir -p dist/i18n && cp src/i18n/*.json dist/i18n/",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^18.14.0",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^5.50.0",
    "@typescript-eslint/parser": "^5.50.0",
    "eslint": "^8.33.0",
    "typescript": "^4.9.5",
    "vsce": "^2.15.0"
  },
  "contributes": {
    "commands": [
      {
        "command": "weather.refreshWeather",
        "title": "%command.weather.refreshWeather%",
        "category": "%command.category%",
        "icon": "$(refresh)"
      },
      {
        "command": "weather.setLocation",
        "title": "%command.weather.setLocation%",
        "category": "%command.category%",
        "icon": "$(location)"
      },
      {
        "command": "weather.showDetails",
        "title": "%command.weather.showDetails%",
        "category": "%command.category%",
        "icon": "$(info)"
      },
      {
        "command": "weather.toggleTemperatureUnit",
        "title": "%command.weather.toggleTemperatureUnit%",
        "category": "%command.category%",
        "icon": "$(symbol-number)"
      },
      {
        "command": "weather.toggleAutoRefresh",
        "title": "%command.weather.toggleAutoRefresh%",
        "category": "%command.category%",
        "icon": "$(sync)"
      },
      {
        "command": "weather.refreshLocation",
        "title": "%command.weather.refreshLocation%",
        "category": "%command.category%",
        "icon": "$(location)"
      },
      {
        "command": "weather.setLanguage",
        "title": "%command.weather.setLanguage%",
        "category": "%command.category%",
        "icon": "$(globe)"
      }
    ],
    "keybindings": [
      {
        "command": "weather.refreshWeather",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "weather.refreshWeather"
        },
        {
          "command": "weather.setLocation"
        },
        {
          "command": "weather.showDetails"
        },
        {
          "command": "weather.toggleTemperatureUnit"
        },
        {
          "command": "weather.toggleAutoRefresh"
        },
        {
          "command": "weather.refreshLocation"
        },
        {
          "command": "weather.setLanguage"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "%config.weather%",
      "properties": {
        "weather.refreshInterval": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 120,
          "description": "%config.weather.autoRefreshInterval.description%"
        },
        "weather.temperatureUnit": {
          "type": "string",
          "default": "C",
          "enum": [
            "C",
            "F"
          ],
          "enumDescriptions": [
            "Celsius",
            "Fahrenheit"
          ],
          "description": "%config.weather.temperatureUnit.description%"
        },
        "weather.city": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "%config.weather.manualCity.description%"
        },
        "weather.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "%config.weather.enableAutoRefresh.description%"
        },
        "weather.language": {
          "type": "string",
          "default": "en-US",
          "enum": [
            "en-US",
            "zh-CN"
          ],
          "enumDescriptions": [
            "%config.weather.language.enum.enUS%",
            "%config.weather.language.enum.zhCN%"
          ],
          "description": "%config.weather.language.description%"
        }
      }
    }
  }
}
